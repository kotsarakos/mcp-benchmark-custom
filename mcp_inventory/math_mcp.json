      "input_schema": {
        "type": "object",
        "properties": {
          "numbers": {
            "type": "array",
            "items": {
              "type": "number"
            },
            "minItems": 1,
            "description": "Array of numbers to sum"
          }
        },
        "required": [
          "numbers"
        ],
        "additionalProperties": false,
        "$schema": "http://json-schema.org/draft-07/schema#"
